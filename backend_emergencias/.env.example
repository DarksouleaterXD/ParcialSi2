DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/emergencias_db
JWT_SECRET=cambiar-por-secreto-largo-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Opcional: envío de credenciales por correo. Si SMTP_HOST está vacío, solo se registra en log.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@emergencias.local
SMTP_USE_TLS=true

# CORS (opcional). Producción: lista cerrada, sin "*", compatible con credenciales (cookies/Authorization).
# CORS_ORIGINS=https://app.ejemplo.com,https://admin.ejemplo.com
# Desarrollo: dejar CORS_ORIGINS vacío para usar localhost:4200 (Angular) + regex localhost:* (Flutter web).
# CORS_ALLOW_LOCALHOST_REGEX=true

# Stripe (test mode). Sin STRIPE_SECRET_KEY, crear PaymentIntent devuelve 503.
# STRIPE_WEBHOOK_SECRET: obtener con `stripe listen --print-secret` o al iniciar
# `stripe listen --forward-to http://127.0.0.1:<PUERTO>/api/pagos/webhook` (mismo
# secreto que usa la CLI para firmar los reenvíos). No commitear valores reales.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Gemini (IA multimodal incidentes). Vacío => fallback local determinístico.
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash
AI_CONFIDENCE_THRESHOLD=0.55
AI_REQUEST_TIMEOUT_SECONDS=60
